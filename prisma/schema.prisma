// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed password for credentials auth
  role          UserRole  @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  progress      Progress[]
  badges        UserBadge[]
  streaks       Streak[]
  reviews       Review[]
  tutoringRequests TutoringRequest[]
  eventLogs     EventLog[]

  @@index([email])
  @@index([role])
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Unit {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   
  order       Int
  heroImage   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
  quizzes     Quiz[]
  tests       Test[]
  skills      Skill[]
  flashcardSets FlashcardSet[]
  progress    Progress[]

  @@index([slug])
  @@index([order])
}

model Lesson {
  id          String      @id @default(cuid())
  slug        String      @unique
  unitId      String
  title       String
  description String      
  type        LessonType
  khanUrl     String?     
  youtubeId   String?
  duration    Int?        // minutes
  order       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  unit        Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  flashcardSets FlashcardSet[]
  progress    Progress[]

  @@index([unitId])
  @@index([slug])
  @@index([order])
}

enum LessonType {
  VIDEO
  READING
  EXERCISE
}

model Quiz {
  id          String   @id @default(cuid())
  unitId      String
  title       String
  description String?  
  timeLimit   Int?     // minutes
  questions   Json     // Array of question objects
  passingScore Int     @default(70)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress    Progress[]

  @@index([unitId])
}

model Test {
  id          String   @id @default(cuid())
  unitId      String
  title       String
  description String?  
  timeLimit   Int?     // minutes
  questions   Json     // Array of question objects
  passingScore Int     @default(70)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  progress    Progress[]

  @@index([unitId])
}

model Skill {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  unitId      String
  description String?  
  createdAt   DateTime @default(now())

  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([unitId])
}

model FlashcardSet {
  id          String     @id @default(cuid())
  lessonId    String?
  unitId      String?
  title       String
  description String?    
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lesson      Lesson?    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  unit        Unit?      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  flashcards  Flashcard[]

  @@index([lessonId])
  @@index([unitId])
}

model Flashcard {
  id          String       @id @default(cuid())
  setId       String
  front       String       
  back        String       
  hint        String?      
  order       Int          @default(0)
  createdAt   DateTime     @default(now())

  set         FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId])
}

model Progress {
  id          String       @id @default(cuid())
  userId      String
  unitId      String?
  lessonId    String?
  quizId      String?
  testId      String?
  status      ProgressStatus @default(NOT_STARTED)
  score       Int?
  lastViewedAt DateTime?   @default(now())
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit        Unit?        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lesson      Lesson?      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quiz        Quiz?        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  test        Test?        @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([unitId])
  @@index([lessonId])
  @@index([quizId])
  @@index([testId])
  @@unique([userId, unitId, lessonId, quizId, testId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Badge {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String     
  icon        String?    // icon name or URL
  createdAt   DateTime   @default(now())

  users       UserBadge[]

  @@index([slug])
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  awardedAt   DateTime @default(now())
  reason      String?  

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([badgeId])
  @@unique([userId, badgeId])
}

model Streak {
  id          String   @id @default(cuid())
  userId      String   @unique
  current     Int      @default(0)
  longest     Int      @default(0)
  lastActiveAt DateTime? @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  rating      Int      // 1-5
  comment     String?  
  moderated   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moderated])
}

model Teacher {
  id          String   @id @default(cuid())
  name        String
  avatar      String?
  bio         String   
  email       String
  officeHours String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tutoringSlots TutoringSlot[]

  @@index([email])
}

model TutoringSlot {
  id          String   @id @default(cuid())
  teacherId   String
  start       DateTime
  end         DateTime
  capacity    Int      @default(5)
  spotsLeft   Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([start])
}

model TutoringRequest {
  id          String           @id @default(cuid())
  userId      String
  type        TutoringRequestType
  topic       String?          
  status      TutoringRequestStatus @default(PENDING)
  scheduledSlotId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
}

enum TutoringRequestType {
  SCHEDULED
  IMMEDIATE
}

enum TutoringRequestStatus {
  PENDING
  MATCHED
  COMPLETED
  CANCELLED
}

model EventLog {
  id          String   @id @default(cuid())
  userId      String
  type        String   // e.g., "lesson_completed", "quiz_attempted", "recommendation_generated"
  payload     Json     // Flexible JSON data
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}